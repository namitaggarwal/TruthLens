    <!-- Accessibility Service -->
    <string name="accessibility_service_label">TruthLens Content Monitor</string>
    <string name="accessibility_service_description">TruthLens uses Accessibility Service to read visible text in selected apps so it can flag potentially misleading content. It never reads passwords, payment screens, or private banking apps. Monitoring is always opt-in and can be disabled at any time from the TruthLens app.</string>

